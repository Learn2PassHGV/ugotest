# ============ UGO website environment variables ============
# Copy to .env.local for local development. On Vercel, set these in
# Project Settings -> Environment Variables.

# --- AI chat assistant (server-side only; never exposed to the browser) ---
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# --- Lead email delivery (Resend: https://resend.com, free tier is plenty) ---
# 1. Create a Resend account, verify the coaches.business domain
# 2. Create an API key and paste it here
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Where enquiries are sent (comma-separate for multiple recipients)
LEAD_TO="sasha@coaches.business"

# The From address (must be on the verified Resend domain once set up)
LEAD_FROM="UGO Website <leads@coaches.business>"

# Optional BCC copy of every lead (e.g. the web manager)
# LEAD_BCC="lckohn.daniel@gmail.com"
